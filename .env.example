# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Flow Chile
FLOW_API_KEY=
FLOW_SECRET_KEY=
FLOW_API_URL=https://sandbox.flow.cl/api

# Meta Pixel
NEXT_PUBLIC_META_PIXEL_ID=

# App — URL pública (Flow urlReturn / webhook, emails, metadata)
# Producción: https://tudominio.cl (sin barra final). Vercel: Project → Settings → Environment Variables.
# Si no está definida, en servidor se usa SITE_URL o https://VERCEL_URL (host del deploy actual).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# SITE_URL=https://tudominio.cl   # opcional; mismo uso que NEXT_PUBLIC_SITE_URL (solo servidor)
NEXT_PUBLIC_SITE_NAME=TheGate

# Email (Resend)
RESEND_API_KEY=
STORE_CONTACT_EMAIL=
STORE_FROM_EMAIL=

# Admin
# Legacy fallback (temporal)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
